      "title": "Inbound Discards",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifInDiscards{instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{ifName}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisLabel": "", "fillOpacity": 20, "lineWidth": 1, "scaleDistribution": { "type": "linear" }, "showPoints": "never" },
          "unit": "pps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Outbound Errors",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ifOutErrors{instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{ifName}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
