{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 20,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Connected Clients",
      "type": "timeseries",
      "targets": [
        {
          "expr": "redis_connected_clients{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 20,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never"
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "redis_memory_used_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{instance=~\"$instance\"} > 0",
          "legendFormat": "{{instance}} max",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 20,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never"
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Ops/sec",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{instance=~\"$instance\"}[$__rate_interval])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 20,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never"
          },
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Replication Offset Lag",
      "type": "timeseries",
      "targets": [
        {
          "expr": "redis_master_repl_offset{instance=~\"$instance\"} - on() group_right() redis_slave_repl_offset{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 20,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never"
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Keyspace Hit Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{instance=~\"$instance\"}[$__rate_interval]) / (rate(redis_keyspace_hits_total{instance=~\"$instance\"}[$__rate_interval]) + rate(redis_keyspace_misses_total{instance=~\"$instance\"}[$__rate_interval])) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 0,
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never"
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Sentinel Status",
      "type": "timeseries",
      "targets": [
        {
          "expr": "redis_sentinel_master_ok{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} master_ok",
          "refId": "A"
        },
        {
          "expr": "redis_sentinel_master_slaves{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} slaves",
          "refId": "B"
        },
        {
          "expr": "redis_sentinel_master_sentinels{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} sentinels",
          "refId": "C"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "redis",
    "sentinel"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "psyclyx-prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(redis_up, instance)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "instance",
        "query": {
          "qryType": 1,
          "query": "label_values(redis_up, instance)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Redis Cluster",
  "uid": "psyclyx-redis-cluster"
}
