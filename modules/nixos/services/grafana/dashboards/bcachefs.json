      "title": "Btree Cache Hit Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(bcachefs_counter{instance=~\"$instance\",uuid=~\"$uuid\",name=\"btree_cache_hit\"}[$__rate_interval]) / (rate(bcachefs_counter{instance=~\"$instance\",uuid=~\"$uuid\",name=\"btree_cache_hit\"}[$__rate_interval]) + rate(bcachefs_counter{instance=~\"$instance\",uuid=~\"$uuid\",name=\"btree_cache_miss\"}[$__rate_interval])) * 100",
          "legendFormat": "{{instance}} {{uuid}}",
          "refId": "A"
        }
      ]
