          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{instance=~\"$instance\", datname!=\"\"}[$__rate_interval])",
          "legendFormat": "{{instance}} {{datname}} rollbacks",
          "refId": "B"
        }
      ]
