        {
          "expr": "pg_stat_activity_count{instance=~\"$instance\", state=\"idle\"}",
          "legendFormat": "{{instance}} idle",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
